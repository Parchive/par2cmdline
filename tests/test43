#!/bin/sh

execdir="$PWD"

# valgrind tests memory usage.
# wine allow for windows testing on linux
if [ -n "${PARVALGRINDOPTS+set}" ]
then
    PARBINARY="valgrind $PARVALGRINDOPTS $execdir/par2"
elif [ "`which wine`" != "" ] && [ -f "$execdir/par2.exe" ]
then
    PARBINARY="wine $execdir/par2.exe"
else
    PARBINARY="$execdir/par2"
fi

if [ -z "$srcdir" ] || [ "." = "$srcdir" ]; then
  srcdir="$PWD"
  TESTDATA="$srcdir/tests"
else
  srcdir="$PWD/$srcdir"
  TESTDATA="$srcdir/tests"
fi

TESTROOT="$PWD"

testname=$(basename $0)
rm -f "$testname.log"
rm -rf "run$testname"

mkdir "run$testname" && cd "run$testname" || { echo "ERROR: Could not change to test directory" ; exit 1; } >&2

banner="Reject repair through dangling symlink"
dashes=`echo "$banner" | sed s/./-/g`

echo $dashes
echo $banner
echo $dashes

mkdir -p work/.config/autostart outside
printf 'symlink escape file body\n' > work/.config/autostart/poc.desktop

(
  cd work || exit 1
  "$PARBINARY" c -q -r100 recovery.par2 .config/autostart/poc.desktop >/dev/null || exit 1
  rm .config/autostart/poc.desktop
  ln -s "$PWD/../outside/escaped-by-repair" .config/autostart/poc.desktop
  "$PARBINARY" r -q recovery.par2 >/dev/null && exit 2
  exit 0
)
status=$?

if [ "$status" -eq 1 ]
then
  echo "ERROR: failed to create test recovery set" >&2
  exit 1
fi

if [ -f outside/escaped-by-repair ]
then
  echo "ERROR: repair wrote through dangling symlink outside repair tree" >&2
  exit 1
fi

if [ "$status" -ne 0 ]
then
  echo "ERROR: repair through dangling symlink succeeded unexpectedly" >&2
  exit 1
fi

echo "Dangling symlink repair target was rejected"

cd "$TESTROOT"
rm -rf "run$testname"

exit 0
